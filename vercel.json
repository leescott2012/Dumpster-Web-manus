{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile || npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/ai-suggest.ts": { "maxDuration": 60, "memory": 1024 },
    "api/ai-caption.ts": { "maxDuration": 30, "memory": 512 },
    "api/ig-scrub.ts": { "maxDuration": 30, "memory": 512 }
  }
}
