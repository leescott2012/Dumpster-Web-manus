# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products in Stripe Dashboard first)
STRIPE_PRICE_CREDITS_100=price_...
STRIPE_PRICE_CREDITS_500=price_...
STRIPE_PRICE_CREDITS_1500=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# ── Sentry (crash + error tracking) ───────────────────────
# Sign up at sentry.io → create a React project → copy DSN
VITE_SENTRY_DSN=https://xxx@oXXX.ingest.us.sentry.io/XXXXX

# For source-map upload at build time (so prod stack traces are readable).
# Create an auth token at: sentry.io/settings/account/api/auth-tokens/ (scope: project:releases)
SENTRY_ORG=my-org-slug
SENTRY_PROJECT=dumpster-web
SENTRY_AUTH_TOKEN=sntrys_...

# ── Upstash Redis (rate limiting + daily budget) ──────────
# Sign up at upstash.com → create Redis DB → copy REST URL + Token
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxx

# ── Daily AI Budget (circuit breaker) ─────────────────────
# Hard ceiling on AI cost per UTC day. AI endpoints return 503 when exceeded.
DAILY_BUDGET_USD=20
DAILY_BUDGET_ALERT_PCT=80

# ── Credit Gate Bypass (TESTING ONLY) ─────────────────────
# Set to "1" to skip per-user credit deduction so testers can iterate without
# running out. Auth + rate limit + daily $ budget still enforce — total spend
# stays capped. Set to "0" or remove to re-enable credit gating.
#
# Both must be set together — the server flag bypasses deduction, the client
# (VITE_) flag stops the "Out of Credits" overlay from popping on the UI.
DISABLE_CREDIT_LIMIT=0
VITE_DISABLE_CREDIT_LIMIT=0
